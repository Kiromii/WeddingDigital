{
    "version": 2,
    "framework": null,
    "builds": [
        { "src": "/api/index.php", "use": "vercel-php@0.6.2" },
        { "src": "/public/build/assets/**", "use": "@vercel/static" },
        { "src": "/public/**", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/build/assets/(.*)", "dest": "/public/build/assets/$1" },
        {
            "src": "/favicon.ico",
            "headers": { "Content-Type": "image/x-icon" },
            "dest": "/public/favicon.ico"
        },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "outputDirectory": "public",
    "env": {
        "APP_NAME": "WeddingDigital",
        "APP_ENV": "production",
        "APP_KEY": "base64:2uaoOybep4OObgORRdFJQ7JmdgbdalHQ9QqKYf2wK1c=",
        "APP_DEBUG": "false",
        "APP_URL": "https://wedding-digital-eight.vercel.app",

        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp",

        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie"
    }
}
